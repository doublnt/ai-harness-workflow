{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Vibe Guardrails Gate Artifact",
  "type": "object",
  "required": [
    "id",
    "task",
    "riskLevel",
    "requiredGates",
    "completedGates",
    "humanApprovalRequired",
    "humanApprovalStatus",
    "unknowns"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "task": {
      "type": "string"
    },
    "riskLevel": {
      "enum": [
        "L0",
        "L1",
        "L2",
        "L3"
      ]
    },
    "requiredGates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "completedGates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "humanApprovalRequired": {
      "type": "boolean"
    },
    "humanApprovalStatus": {
      "enum": [
        "not-required",
        "pending",
        "approved",
        "rejected"
      ]
    },
    "tests": {
      "type": "object"
    },
    "rollbackPlan": {
      "type": "string"
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
